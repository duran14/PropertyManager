{
  "name": "property-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Financial Integrity Bridge — SaaS de Property Management para British Columbia (multi-tenant)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck && pnpm -r --filter \"./apps/**\" run typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @property-manager/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @property-manager/api exec tsx prisma/seed.ts",
    "db:studio": "pnpm --filter @property-manager/api exec prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
