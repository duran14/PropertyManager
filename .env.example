# =============================================================================
# Plantilla de variables de entorno — Property Manager (MVP)
# Copia este archivo a .env en la raíz y rellena los valores.
# NUNCA subas .env al repositorio.
# =============================================================================

# --- Entorno ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Base de datos (Postgres local vía docker-compose, puerto 5433) ---
DATABASE_URL="postgresql://pm_dev:pm_dev_password@localhost:5433/property_manager?schema=public"

# --- Redis (cola de jobs / BullMQ, puerto 6380) ---
REDIS_URL="redis://localhost:6380"

# --- API ---
API_PORT=4000
API_URL="http://localhost:4000"
WEB_URL="http://localhost:5173"

# --- Document/object storage ---
# Local by default for mock/staging. Later this can point to S3/R2-backed URLs.
DOCUMENT_STORAGE_DIR=".storage/documents"
DOCUMENT_STORAGE_PUBLIC_BASE_URL=

# --- Autenticación (JWT) ---
# Genera con: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- Cifrado de credenciales de integración (por tenant) ---
# Genera con: openssl rand -base64 32
INTEGRATION_ENCRYPTION_KEY=change-me-32-byte-encryption-key

# --- IA (Z.ai — GLM) ---
# Hoy opcional: sin clave, el adapter GLM cae a modo mock.
ZAI_API_KEY=
ZAI_BASE_URL="https://api.z.ai/api/paas/v4"
GLM_REASONING_MODEL="glm-5.2"
GLM_OCR_MODEL="glm-ocr"

# --- Integraciones externas (todas OPCIONALES en MVP; sin valor → mock) ---
# Buildium
BUILDIUM_CLIENT_ID=
BUILDIUM_CLIENT_SECRET=

# QuickBooks Online
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox

# Twilio (WhatsApp/SMS)
# Setting TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN enables real Twilio sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
TWILIO_DEFAULT_TENANT_ID=tenant_demo_pm

# Plaid (lectura de saldos)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Stripe Connect (ejecución de pagos — fuera de alcance del MVP)
STRIPE_SECRET_KEY=

# Telegram shared bot for MVP/demo
# Put the BotFather token here to let the app answer through your existing bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_TENANT_ID=tenant_demo_pm

# --- Umbrales HITL por defecto (0.0 a 1.0) ---
DEFAULT_CONFIDENCE_THRESHOLD=0.85
